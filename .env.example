# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=realty_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=realty

# ─── Directus ──────────────────────────────────────────────────────────────────
# JWT signing secret — shared with the FastAPI pm service for token verification
DIRECTUS_SECRET=change_me_64_char_random_string_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change_me_strong_password
# Internal URL (used by docker compose services): http://directus:8055
# External URL (used by browsers and caddy): https://yourdomain.com/cms
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_CORS_ORIGIN=http://localhost:3000

# ─── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=realty-media
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# CDN / public URL for listing media (set up a custom domain in Cloudflare R2)
R2_PUBLIC_URL=https://media.yourdomain.com

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=postmark
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_CENTRAL_INBOX=inquiries@yourdomain.com

# ─── Next.js public site ───────────────────────────────────────────────────────
# NEXT_PUBLIC_ vars are exposed to the browser — never put secrets here
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
# Holiday theme preview — set to a theme ID to force it regardless of date.
# Valid values: new_year valentines holi easter keti_koti eid diwali independence christmas
# Leave unset (or remove entirely) in production — themes activate automatically by date.
# NEXT_PUBLIC_FORCE_THEME=christmas
# Internal Docker network URL — used for server-side SSR requests inside the container
# DIRECTUS_INTERNAL_URL=http://directus:8055   # set automatically in docker-compose
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-only token for SSR/ISR reads from Directus — NOT NEXT_PUBLIC_
DIRECTUS_SERVER_TOKEN=your_directus_server_token_here
# Public URL of the PM API (browser-accessible)
# Local dev: http://localhost:8001 (when pm is run directly, not via Docker)
# Production: https://yourdomain.com/api/pm (routed through Caddy — no direct port)
NEXT_PUBLIC_PM_URL=http://localhost:8001

# ─── FastAPI PM service ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ─── Caddy ─────────────────────────────────────────────────────────────────────
# Your production domain — Caddy uses this for TLS provisioning
DOMAIN=yourdomain.com
# Email for Let's Encrypt certificate notifications
CADDY_ADMIN_EMAIL=admin@yourdomain.com
# Comma-separated CIDR list of IPs allowed to access /cms/admin (your office/VPN IPs)
CADDY_ADMIN_IPS=1.2.3.4/32
